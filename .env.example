# MurmuraScope — Environment Variables
# For advanced usage, see: .env.advanced.example

# ── REQUIRED (Minimum to run) ────────────────────────────────────────────────
# To run without API keys, set DEMO_MODE=true
DEMO_MODE=false

# Preferred provider: OpenRouter (Unified access to DeepSeek, Claude, Llama 3)
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Security: Generate with `openssl rand -hex 32`
AUTH_SECRET_KEY=your-secret-key-here

# ── ADVANCED (Optional) ──────────────────────────────────────────────────────
DEBUG=false
DATABASE_PATH=data/murmuroscope.db
LOG_LEVEL=INFO

# See .env.advanced.example for:
# - Google / OpenAI / Anthropic direct integration
# - External Macro Feed (FRED / World Bank)
# - Simulation Concurrency Limits
# - Custom Frontend URL
