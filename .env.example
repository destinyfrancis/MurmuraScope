# Morai — Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your API keys.

# ── LLM Providers ─────────────────────────────────────────────────────────────
# Agent decisions (used for simulation)
AGENT_LLM_PROVIDER=openrouter
AGENT_LLM_MODEL=deepseek/deepseek-v3.2

# Report generation
LLM_PROVIDER=google
GOOGLE_REPORT_MODEL=gemini-3.1-pro-preview

# ── API Keys ──────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your-openrouter-key
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Optional: enhanced data pipeline
FRED_API_KEY=your_fred_api_key_here

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -hex 32
# In DEBUG mode (DEBUG=true), a random key is generated at startup,
# which means all JWTs are invalidated on every restart.
# Without this key set and DEBUG=false, the server will refuse to start.
AUTH_SECRET_KEY=your-secret-key-here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=data/murmuroscope.db

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5001
DEBUG=false
FRONTEND_URL=http://localhost:8080

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_FILE=logs/murmuroscope.log
LOG_LEVEL=INFO

# ── Simulation ────────────────────────────────────────────────────────────────
# Max concurrent LLM requests per round (tune to your API rate limits)
SIMULATION_CONCURRENCY_LIMIT=50
