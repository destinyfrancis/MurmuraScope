# HKSimEngine Environment Variables

# LLM Provider Selection
# Options: openrouter, fireworks, google, deepseek, anthropic
LLM_PROVIDER=openrouter

# LLM API Keys
DEEPSEEK_API_KEY=sk-your-deepseek-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENAI_API_KEY=sk-your-openai-key
OPENROUTER_API_KEY=sk-or-your-openrouter-key
FIREWORKS_API_KEY=your-fireworks-api-key

# Google Generative AI (set LLM_PROVIDER=google to activate)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_AGENT_MODEL=gemini-3-flash-preview   # for agent decisions
GOOGLE_REPORT_MODEL=gemini-3.1-pro-preview  # for report generation

# Data Pipeline API Keys
FRED_API_KEY=your_fred_api_key_here  # https://fred.stlouisfed.org/docs/api/api_key.html

# Database
DATABASE_PATH=data/hksimengine.db

# Server
HOST=0.0.0.0
PORT=5001
DEBUG=false

# OASIS
OASIS_PATH=/path/to/oasis
OASIS_PYTHON=python3.10

# Frontend
FRONTEND_URL=http://localhost:3000
